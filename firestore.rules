rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signed() { return request.auth != null; }
    function owner(userId) { return signed() && request.auth.uid == userId; }
    match /users/{userId} {
      allow read, write: if owner(userId);
      match /{document=**} { allow read, write: if owner(userId); }
    }
    match /{document=**} { allow read, write: if false; }
  }
}
